DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vendi
FRONTEND_URL=http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:4000/api/v1/auth/github/callback
ENCRYPTION_KEY=
# Daytona sandbox provider
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=https://app.daytona.io/api
DAYTONA_TARGET=us
# Optional: boot sandboxes from a pre-built snapshot (otherwise the default image is used)
DAYTONA_SNAPSHOT=
# Optional: set to "true" to pre-build a Daytona snapshot during project setup
DAYTONA_BUILD_SNAPSHOT=
# LLM provider: vercel | openai | openrouter | gemini | groq  (set the matching key below)
LLM_PROVIDER=vercel
AI_GATEWAY_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
# Google Gemini (OpenAI-compatible endpoint) — use with LLM_PROVIDER=gemini
GEMINI_API_KEY=
# Groq API (free tier available) — use with LLM_PROVIDER=groq
GROQ_API_KEY=
